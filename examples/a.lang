int fibonacci(int n) {
    if (n < 2) {
        return n
    }
    int a = 0;
    int b = 1;
    int i = 2;
    int temp = 0;
    
    while (i <= n) {
        temp = a + b;
        a = b;
        b = temp;
        i = i + 1;
    }
    return b;
}
int main(int argc, int argv){
    exit(fibonacci(10));
}
