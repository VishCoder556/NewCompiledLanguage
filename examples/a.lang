int fibonacci(int n) {
    if (n < 2) {
        return n
    }
    int a = 0;
    int b = 1;
    int i = 2;
    int temp = 0;
    
    while (i <= n) {
        temp = a + b;
        a = b;
        b = temp;
        i = i + 1;
    }
    return b;
}
int print_fibonacci(int n){
    printf("Fibonacci(%d) = %d!\n", n, fibonacci(n))
}
int main(int argc, int argv){
    int i = 0;
    ptr<int> a = cast(ptr<int>, 5)

    while (i <= 10) {
        print_fibonacci(i)
        i = i + 1
    }
    exit(0)
}
