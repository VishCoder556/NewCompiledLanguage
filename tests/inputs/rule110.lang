#!include "examples/include/std.lang"

int main(){
    int[100] current_board
    int[100] next_board
    
    int i = 0;
    while (i < 100){
        current_board[i] = 0;
        i = i + 1
    }

    current_board[99] = 1;
    i = 0;
    while (i < 40){
        // Keep it at 40 for now
        int j = 0
        while (j < 100){
            if (current_board[j] == 0){
                printf(" ");
            }else {
                printf("*");
            }
            j = j + 1
        }
        printf("\n")
        j = 1
        while (j < 99){
            int a = current_board[j - 1]
            int b = current_board[j]
            int c = current_board[j + 1]
            int pattern = cast(int, (a << 2) | (b << 1) | (c << 0));
            next_board[j] = (110 >> pattern) & 1;
            j = j + 1
        }
        j = 0
        while (j < 100){
            current_board[j] = next_board[j]
            j = j + 1
        }
        i = i + 1
    }
    return 0;
}
